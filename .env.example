# =================================================================
# Variables de entorno — ApexMetrics
# Copiar a .env y completar los valores reales antes de usar.
# NO comitear el archivo .env al repositorio.
# =================================================================

# --- Base de datos PostgreSQL ------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/apexmetrics_db
SPRING_DATASOURCE_USERNAME=apexuser
SPRING_DATASOURCE_PASSWORD=apexpass

POSTGRES_DB=apexmetrics_db
POSTGRES_USER=apexuser
POSTGRES_PASSWORD=apexpass

# --- Autenticacion JWT -------------------------------------------
JWT_SECRET=CAMBIAR-EN-PRODUCCION-clave-secreta-minimo-32-caracteres
JWT_EXPIRATION_MS=3600000

# --- SonarQube (tokens de analisis) ------------------------------
SONAR_TOKEN_BACKEND=
SONAR_TOKEN_FRONTEND=
